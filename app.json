{
  "expo": {
    "name": "ResQ PH",
    "slug": "resq-ph",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "resqph",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "ph.resq.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#D32F2F"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECORD_AUDIO",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/resqlogo.jpg",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "ResQ PH needs camera access to use the flashlight during emergencies."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ResQ PH uses your location to guide emergency responders to you."
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
